---
import Base from '../layouts/base.astro'
import { WebsiteNavbar } from '../components/website-navbar'
import HeroSection from '../components/hero-section.astro'
import FerrisKeySpotlightSection from '../components/ferriskey-spotlight-section.astro'
import PrinciplesSection from '../components/principles-section.astro'
import IamSection from '../components/iam-section.astro'
import ProjectsSection from '../components/projects-section.astro'
import LatestArticlesSection from '../components/latest-articles-section.astro'
import ContactSection from '../components/contact-section.astro'
import { Footer } from '@explainer/ui'
import { siteConfig } from '../config'
import { ui } from '../i18n/ui'

const appUrlOverrides = {
  website: import.meta.env.PUBLIC_WEBSITE_URL,
  docs: import.meta.env.PUBLIC_DOCS_URL,
  blog: import.meta.env.PUBLIC_BLOG_URL,
}

const translations = ui.fr
const thumbnails = { en: '/thumbnail.png', fr: '/thumbnails/fr/thumbnail.png' }
---

<Base title="Baptiste Parmantier" description="Software Architect and IAM expert with 10+ years of experience. Co-founder of FerrisKey. Designing scalable distributed systems." thumbnail="/thumbnail.png">
  <WebsiteNavbar appUrlOverrides={appUrlOverrides} client:load transition:persist />

  <HeroSection />
  <FerrisKeySpotlightSection />
  <PrinciplesSection />
  <IamSection />
  <ProjectsSection />
  <LatestArticlesSection />
  <ContactSection />

  <div class="mx-auto max-w-6xl px-6">
    <Footer config={siteConfig} appUrlOverrides={appUrlOverrides} client:load />
  </div>
</Base>

<script is:inline define:vars={{ translations, thumbnails }}>
  function detectLocale() {
    const match = document.cookie.match(/(?:^|; )locale=([^;]*)/)
    const cookie = match ? match[1] : null
    if (cookie === 'en' || cookie === 'fr') return cookie

    const browser = (navigator.language || '').split('-')[0]
    if (browser === 'en' || browser === 'fr') return browser
    return 'en'
  }

  function applyTranslations() {
    const locale = detectLocale()
    document.documentElement.lang = locale

    if (locale === 'en') {
      document.querySelectorAll('[data-t]').forEach(function (el) {
        if (el.dataset.tDefault) el.textContent = el.dataset.tDefault
      })
      return
    }

    document.querySelectorAll('[data-t]').forEach(function (el) {
      const key = el.getAttribute('data-t')
      if (!el.dataset.tDefault) el.dataset.tDefault = el.textContent
      if (translations[key]) el.textContent = translations[key]
    })

    const thumb = thumbnails[locale] || thumbnails['en']
    document.querySelectorAll('meta[property="og:image"], meta[name="twitter:image"]').forEach(function (el) {
      el.setAttribute('content', thumb)
    })
  }

  applyTranslations()
  document.addEventListener('astro:after-swap', applyTranslations)
</script>
