---
import { Icon } from "@iconify/react";

const pillars = [
  {
    icon: "lucide:shield-check",
    titleKey: "pillars.card1.title",
    descKey: "pillars.card1.description",
    title: "Identity & Architecture",
    description: "I design systems at the domain level — defining service boundaries, API contracts, and data ownership before touching a framework. My IAM expertise (OIDC, policies, multi-tenancy) comes from building FerrisKey: an identity platform where correctness isn't optional.",
    proofLabel: "FerrisKey",
    proofHref: "#ferriskey",
    internal: true,
  },
  {
    icon: "lucide:network",
    titleKey: "pillars.card2.title",
    descKey: "pillars.card2.description",
    title: "Distributed Systems",
    description: "I build services that coordinate reliably at scale. Event-driven architectures, Kubernetes orchestration, and consistency models designed for failure — not just for the happy path.",
    proofLabel: "Ferriscord",
    proofHref: "https://github.com/ferrislabs",
    internal: false,
  },
  {
    icon: "lucide:activity",
    titleKey: "pillars.card3.title",
    descKey: "pillars.card3.description",
    title: "Production Lifecycle",
    description: "I don't stop at the deploy. CI/CD pipelines, structured observability with Prometheus and Loki, and the mindset of an owner — not a contractor. If it pages at 3am, I'm the one who fixed the design that caused it.",
    proofLabel: "GitHub Actions + Prometheus",
    proofHref: "https://github.com/ferriskey/ferriskey",
    internal: false,
  },
];
---

<section class="relative py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header: left-aligned -->
    <div class="mb-16" data-reveal="fade-up">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3" data-t="pillars.label">
        What I Do
      </p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl" data-t="pillars.title">
        Three things I'm built for
      </h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-2xl" data-t="pillars.description">
        Not a list of frameworks. What I actually deliver, end to end.
      </p>
    </div>

    <!-- Numbered rows -->
    <div class="divide-y divide-border/40">
      {pillars.map((p, i) => (
        <div
          class="group relative grid grid-cols-1 lg:grid-cols-[96px_1fr_auto] gap-6 lg:gap-10 py-10 -mx-6 px-6 transition-colors duration-300 hover:bg-primary/[2.5%]"
          data-reveal="fade-up"
          data-reveal-delay={String(i * 120)}
        >
          <!-- Left accent on hover -->
          <div class="absolute left-0 top-0 bottom-0 w-0.5 rounded-full bg-primary/0 group-hover:bg-primary/50 transition-all duration-300" aria-hidden="true"></div>

          <!-- Number -->
          <div class="flex items-start pt-0.5">
            <span
              class="text-[4.5rem] font-mono font-bold leading-none text-foreground/[8%] group-hover:text-primary/20 transition-colors duration-300 select-none"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
          </div>

          <!-- Content -->
          <div class="min-w-0">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex items-center justify-center size-8 rounded-lg bg-primary/10 shrink-0 group-hover:bg-primary/15 transition-colors duration-300">
                <Icon icon={p.icon} className="size-4 text-primary" client:load />
              </div>
              <h3 class="text-lg font-semibold text-foreground" data-t={p.titleKey}>
                {p.title}
              </h3>
            </div>
            <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl" data-t={p.descKey}>
              {p.description}
            </p>
          </div>

          <!-- Link -->
          <div class="flex items-center lg:justify-end shrink-0">
            <a
              href={p.proofHref}
              target={p.internal ? undefined : "_blank"}
              rel={p.internal ? undefined : "noopener noreferrer"}
              class="inline-flex items-center gap-2 rounded-lg border border-primary/25 bg-primary/[6%] px-3 py-1.5 text-xs font-semibold text-primary hover:border-primary/50 hover:bg-primary/[10%] transition-all duration-200"
            >
              {p.proofLabel}
              <Icon
                icon={p.internal ? "lucide:arrow-down" : "lucide:arrow-up-right"}
                className="size-3 shrink-0"
                client:load
              />
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
