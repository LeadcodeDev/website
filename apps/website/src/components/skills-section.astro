---
import { Icon } from "@iconify/react";

const stack = [
  { icon: "devicon:rust", name: "Rust" },
  { icon: "devicon:typescript", name: "TypeScript" },
  { icon: "devicon:dart", name: "Dart" },
  { icon: "devicon:kubernetes", name: "Kubernetes" },
  { icon: "devicon:docker", name: "Docker" },
  { icon: "devicon:postgresql", name: "PostgreSQL" },
  { icon: "devicon:github", name: "GitHub Actions" },
  { icon: "simple-icons:prometheus", name: "Prometheus" },
  { icon: "devicon:react", name: "React" },
  { icon: "devicon:vuejs", name: "Vue.js" },
  { icon: "devicon:nodejs", name: "Node.js" },
];
---

<div class="border-y border-border/20 py-8">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
      <span class="text-xs font-semibold text-muted-foreground/30 uppercase tracking-widest" data-t="skills.label">
        Stack
      </span>
      {stack.map((item) => (
        <div class="flex items-center gap-2 text-muted-foreground/50 hover:text-muted-foreground/80 transition-colors duration-200 cursor-default">
          <Icon icon={item.icon} className="size-4" client:load />
          <span class="text-xs font-medium">{item.name}</span>
        </div>
      ))}
    </div>
  </div>
</div>
