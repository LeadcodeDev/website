---
import { Icon } from "@iconify/react"
import { readdirSync, readFileSync } from "node:fs"
import { join } from "node:path"

interface BlogPost {
  title: string
  description: string
  date: Date
  tags: string[]
  slug: string
  cover?: string
}

function parseFrontmatter(content: string): Record<string, any> {
  const match = content.match(/^---\n([\s\S]*?)\n---/)
  if (!match) return {}

  const yaml = match[1]
  const data: Record<string, any> = {}

  for (const line of yaml.split('\n')) {
    const kv = line.match(/^(\w[\w.]*)\s*:\s*(.+)$/)
    if (!kv) continue
    const [, key, rawValue] = kv
    let value: any = rawValue.trim()

    if (value.startsWith('[') && value.endsWith(']')) {
      value = value.slice(1, -1).split(',').map((s: string) => s.trim().replace(/^['"]|['"]$/g, ''))
    }
    else if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
      value = value.slice(1, -1)
    }

    data[key] = value
  }

  return data
}

function loadBlogPosts(locale: string): BlogPost[] {
  const postsDir = join(process.cwd(), '..', 'blog', 'src', 'content', 'posts', locale)
  try {
    const files = readdirSync(postsDir).filter((f) => f.endsWith('.mdx') || f.endsWith('.md'))
    const posts: BlogPost[] = []

    for (const file of files) {
      const content = readFileSync(join(postsDir, file), 'utf-8')
      const data = parseFrontmatter(content)
      if (data.status !== 'published') continue

      posts.push({
        title: data.title ?? '',
        description: data.description ?? '',
        date: new Date(data.date),
        tags: Array.isArray(data.tags) ? data.tags : [],
        slug: file.replace(/\.mdx?$/, '').replace(/ /g, '-'),
        cover: data.cover,
      })
    }

    return posts.sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 3)
  } catch {
    return []
  }
}

const blogUrl = import.meta.env.PUBLIC_BLOG_URL || ''
const enPosts = loadBlogPosts('en')
const frPosts = loadBlogPosts('fr')

function formatDate(date: Date, locale: string) {
  return date.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' })
}
---

{enPosts.length > 0 && (
  <section id="articles" class="py-24 sm:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Section header -->
      <div class="text-center mb-16" data-reveal="fade-up">
        <p
          class="text-sm font-semibold text-primary uppercase tracking-widest mb-3"
          data-t="articles.label"
        >
          Blog
        </p>
        <h2
          class="text-3xl font-bold text-foreground sm:text-4xl"
          data-t="articles.title"
        >
          Latest articles
        </h2>
        <p
          class="mt-4 text-lg text-muted-foreground max-w-2xl mx-auto text-balance"
          data-t="articles.description"
        >
          Stay up to date with the latest news and updates.
        </p>
      </div>

      <!-- EN articles -->
      <div data-locale-articles="en" class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {enPosts.map((post, i) => (
          <article
            class="post-card group"
            data-reveal="fade-up"
            data-reveal-delay={String(i * 150)}
          >
            <a
              href={`${blogUrl}/en/${post.slug}`}
              class="post-card-link block rounded-xl overflow-hidden relative border border-transparent hover:border-primary/20 transition-colors duration-400"
            >
              <div class="pointer-events-none absolute inset-0 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-linear-to-b from-primary/20 via-primary/10 to-transparent"></div>
              <div class="post-card-inner transition-transform duration-300 ease-out">
                <!-- Image -->
                <div class="post-card-img rounded-t-xl bg-muted aspect-16/10 shrink-0 rounded-xl">
                  {post.cover ? (
                    <img src={post.cover} alt={post.title} class="w-full h-full rounded-xl object-cover" loading="lazy" />
                  ) : (
                    <img src={`${blogUrl}/en/${post.slug}/thumbnail.png`} alt={post.title} class="w-full h-full rounded-xl object-cover" loading="lazy" />
                  )}
                </div>
                <!-- Body -->
                <div class="post-card-body relative z-30 p-3 flex flex-col">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    {post.tags.slice(0, 3).map((tag) => (
                      <span class="rounded border border-primary/30 bg-primary/10 text-primary group-hover:border-border group-hover:bg-background group-hover:text-foreground px-2 py-px text-[9px] font-semibold uppercase tracking-wider transition-colors duration-300">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <time class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                    {formatDate(post.date, 'en')}
                  </time>
                  <h3 class="font-bold text-lg leading-snug mt-1.5 line-clamp-2">
                    {post.title}
                  </h3>
                  {post.description && (
                    <p class="post-card-desc text-sm text-muted-foreground mt-3 line-clamp-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100">
                      {post.description}
                    </p>
                  )}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- FR articles -->
      <div data-locale-articles="fr" class="grid grid-cols-1 md:grid-cols-3 gap-6" style="display: none;">
        {frPosts.map((post, i) => (
          <article
            class="post-card group"
            data-reveal="fade-up"
            data-reveal-delay={String(i * 150)}
          >
            <a
              href={`${blogUrl}/fr/${post.slug}`}
              class="post-card-link block rounded-xl overflow-hidden relative border border-transparent hover:border-primary/20 transition-colors duration-400"
            >
              <div class="pointer-events-none absolute inset-0 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-linear-to-b from-primary/20 via-primary/10 to-transparent"></div>
              <div class="post-card-inner transition-transform duration-300 ease-out">
                <!-- Image -->
                <div class="post-card-img rounded-t-xl bg-muted aspect-16/10 shrink-0 rounded-xl">
                  {post.cover ? (
                    <img src={post.cover} alt={post.title} class="w-full h-full rounded-xl object-cover" loading="lazy" />
                  ) : (
                    <img src={`${blogUrl}/fr/${post.slug}/thumbnail.png`} alt={post.title} class="w-full h-full rounded-xl object-cover" loading="lazy" />
                  )}
                </div>
                <!-- Body -->
                <div class="post-card-body relative z-30 p-3 flex flex-col">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    {post.tags.slice(0, 3).map((tag) => (
                      <span class="rounded border border-primary/30 bg-primary/10 text-primary group-hover:border-border group-hover:bg-background group-hover:text-foreground px-2 py-px text-[9px] font-semibold uppercase tracking-wider transition-colors duration-300">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <time class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                    {formatDate(post.date, 'fr')}
                  </time>
                  <h3 class="font-bold text-lg leading-snug mt-1.5 line-clamp-2">
                    {post.title}
                  </h3>
                  {post.description && (
                    <p class="post-card-desc text-sm text-muted-foreground mt-3 line-clamp-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100">
                      {post.description}
                    </p>
                  )}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- View all -->
      <div class="mt-10 text-center" data-reveal="fade-up" data-reveal-delay="300">
        <a
          href={blogUrl}
          class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors"
        >
          <span data-t="articles.viewAll">View all articles</span>
          <Icon icon="lucide:arrow-right" className="size-4" client:load />
        </a>
      </div>
    </div>
  </section>
)}

<script>
  function showLocaleArticles() {
    const match = document.cookie.match(/(?:^|; )locale=([^;]*)/)
    const cookie = match ? match[1] : null
    const browser = (navigator.language || '').split('-')[0]
    const locale = (cookie === 'en' || cookie === 'fr') ? cookie
      : (browser === 'en' || browser === 'fr') ? browser : 'en'

    document.querySelectorAll('[data-locale-articles]').forEach(function (el) {
      ;(el as HTMLElement).style.display = el.getAttribute('data-locale-articles') === locale ? '' : 'none'
    })
  }

  function initPostCards() {
    const cards = document.querySelectorAll('.post-card')
    const measurements: { card: HTMLElement; link: HTMLElement; body: HTMLElement; imgHeight: number; bodyNoHidden: number }[] = []

    cards.forEach((card) => {
      const link = card.querySelector('.post-card-link') as HTMLElement | null
      const img = card.querySelector('.post-card-img') as HTMLElement | null
      const body = card.querySelector('.post-card-body') as HTMLElement | null
      if (!link || !img || !body) return

      link.style.height = ''
      body.style.minHeight = ''

      const imgHeight = img.offsetHeight
      const desc = card.querySelector('.post-card-desc') as HTMLElement | null

      if (desc) desc.style.display = 'none'
      const bodyNoHidden = body.offsetHeight
      if (desc) desc.style.display = ''

      measurements.push({ card: card as HTMLElement, link, body, imgHeight, bodyNoHidden })
    })

    const maxCardHeight = Math.max(...measurements.map((m) => m.imgHeight + m.bodyNoHidden))

    measurements.forEach(({ card, link, body, imgHeight }) => {
      link.style.height = `${maxCardHeight}px`
      body.style.minHeight = `${maxCardHeight}px`
      const inner = card.querySelector('.post-card-inner') as HTMLElement | null
      if (inner) {
        card.addEventListener('mouseenter', () => { inner.style.transform = `translateY(-${imgHeight}px)` })
        card.addEventListener('mouseleave', () => { inner.style.transform = '' })
      }
    })
  }

  showLocaleArticles()
  initPostCards()
  window.addEventListener('resize', initPostCards)
  document.addEventListener('astro:after-swap', () => {
    showLocaleArticles()
    initPostCards()
  })
</script>
