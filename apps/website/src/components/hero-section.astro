---
import { BackgroundAnimation } from './background-animation'
import { Icon } from '@iconify/react'
import { Button } from '@explainer/ui'
---

<style>
  .h-in {
    opacity: 0;
    transform: translateY(14px);
    animation: h-reveal 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes h-reveal {
    to { opacity: 1; transform: none; }
  }
</style>

<div class="relative px-4 sm:px-6 lg:px-8 flex flex-col pt-10 sm:pt-32 lg:pt-36 overflow-hidden">
  <div class="absolute inset-0 -z-20 w-full">
    <BackgroundAnimation client:load />
  </div>

  <div
    class="absolute inset-0 -z-5 pointer-events-none"
    style="clip-path: inset(0 -100vw 0 -100vw);"
    aria-hidden="true"
  >
    <div
      class="absolute -top-16 -left-16 w-56 h-56 sm:-top-32 sm:-left-32 sm:w-md sm:h-112 rounded-full border-2 border-primary/10"
    >
      <div
        class="absolute inset-0 m-auto w-32 h-32 sm:w-80 sm:h-80 rounded-full border border-primary/[0.07]"
      >
      </div>
    </div>

    <div
      class="hidden sm:block absolute -top-24 -right-24 w-80 h-80 rounded-full border-2 border-primary/10"
    >
    </div>

    <div
      class="hidden sm:block absolute top-1/2 -left-16 w-48 h-48 rounded-full border border-primary/8 -translate-y-1/2"
    >
    </div>

    <div
      class="hidden sm:block absolute -bottom-16 -right-16 w-48 h-48 rounded-full border-2 border-primary/8"
    >
    </div>

    <!-- Floating dots -->
    <div
      class="hidden sm:block absolute top-1/4 right-[15%] size-3 rounded-full bg-primary/10"
    >
    </div>
    <div
      class="hidden sm:block absolute top-[40%] left-[25%] size-2 rounded-full bg-primary/8"
    >
    </div>
    <div
      class="hidden sm:block absolute bottom-1/3 right-1/3 size-2.5 rounded-full bg-primary/9"
    >
    </div>
  </div>

  <!-- Bottom-left circle -->
  <div
    class="hidden sm:block absolute bottom-0 left-[33%] -translate-x-1/2 -z-5 pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="absolute -bottom-24 -left-32 w-64 h-64 rounded-full border-2 border-primary/10"
    >
    </div>
  </div>

  <!-- Bottom separator -->
  <div class="absolute bottom-0 inset-x-0 h-px bg-linear-to-r from-transparent via-border to-transparent"></div>

  <div class="w-full max-w-6xl mx-auto pb-16 lg:pb-20">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <div class="h-in" style="animation-delay: 0ms;">
          <a
            href="#ferriskey"
            class="rounded-lg font-semibold inline-flex items-center gap-2 transition-colors px-4 py-1.5 text-xs ring ring-inset ring-primary/50 text-primary hover:bg-primary/10 active:bg-primary/10 no-underline"
            data-t="hero.badge"
          >
            Rust, IAM and distributed systems
            <Icon icon="mdi:arrow-right" className="size-3.5" client:load />
          </a>
        </div>

        <div class="h-in" style="animation-delay: 80ms;">
          <h1 class="mt-6 text-4xl text-pretty tracking-tight text-foreground font-semibold sm:text-6xl">
            <span data-t="hero.title">Baptiste Parmantier,</span><br>
            <span data-t="hero.headline">architect for robust and scalable systems</span>
          </h1>
        </div>
        <p
          class="h-in text-lg sm:text-xl/8 text-muted-foreground text-pretty mt-6 max-w-2xl"
          style="animation-delay: 160ms;"
          data-t="hero.description"
        >
          I build IAM primitives, distributed architectures and production systems. From the first API contract to the last alert resolved.
        </p>
        <div class="h-in pt-8 flex flex-wrap gap-x-4 gap-y-3" style="animation-delay: 240ms;">
          <Button size="lg" className="cursor-pointer" client:load>
            <a href="#ferriskey" class="flex items-center gap-2">
              <span data-t="hero.primaryAction">View my projects</span>
              <Icon icon="mdi:arrow-right" aria-hidden="true" className="size-5" client:load />
            </a>
          </Button>
          <Button variant="outline" size="lg" className="cursor-pointer" client:load>
            <a
              href="https://github.com/LeadcodeDev"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2"
            >
              <Icon icon="mdi:github" aria-hidden="true" className="size-5" client:load />
              <span data-t="hero.secondaryAction">GitHub</span>
            </a>
          </Button>
        </div>
        <div class="h-in mt-8 flex gap-x-8 gap-y-3 flex-wrap" style="animation-delay: 320ms;">
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <Icon icon="mdi:language-rust" className="size-4 text-primary" client:load />
            <span data-t="hero.tag1">Rust</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <Icon icon="mdi:shield-key-outline" className="size-4 text-primary" client:load />
            <span data-t="hero.tag2">IAM and security</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <Icon icon="mdi:source-branch" className="size-4 text-primary" client:load />
            <span data-t="hero.tag3">Open source lead</span>
          </div>
        </div>
      </div>
      <div>
        <div class="overflow-hidden rounded-lg border bg-background">
          <img
            src="/me.webp"
            alt="Baptiste Parmantier"
            class="aspect-square w-full object-cover object-top"
            loading="eager"
          />
        </div>
        <div class="mt-4 grid grid-cols-3 gap-3">
          <div class="rounded-lg border bg-background p-4">
            <p class="text-2xl font-semibold text-foreground">Rust</p>
            <p class="mt-1 text-xs text-muted-foreground">services, CLI, APIs</p>
          </div>
          <div class="rounded-lg border bg-background p-4">
            <p class="text-2xl font-semibold text-foreground">IAM</p>
            <p class="mt-1 text-xs text-muted-foreground">Keycloak, OIDC</p>
          </div>
          <div class="rounded-lg border bg-background p-4">
            <p class="text-2xl font-semibold text-foreground">K8s</p>
            <p class="mt-1 text-xs text-muted-foreground">OPA, AuthZen, MCP</p>
          </div>
        </div>

      </div>

    </div>
  </div>
</div>
