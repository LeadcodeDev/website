---
import { Icon } from "@iconify/react";

const projects = [
  {
    titleKey: "projects.ferriskey.title",
    descKey: "projects.ferriskey.description",
    title: "FerrisKey",
    logoUrl: "https://ferriskey.rs/logo.svg",
    description: "A fast and secure API key management service built with Rust and Axum. Role-based access control and usage analytics.",
    techIcons: [
      { icon: "devicon:rust", label: "Rust" },
      { icon: "material-icon-theme:react", label: "React" },
      { icon: "devicon:tailwindcss", label: "Tailwind" },
      { icon: "material-icon-theme:kubernetes", label: "Kubernetes" },
    ],
    highlights: [
      { icon: "lucide:shield-check", text: "Role-based access control" },
      { icon: "lucide:bar-chart-3", text: "Usage analytics & monitoring" },
      { icon: "lucide:zap", text: "High-performance Rust backend" },
    ],
    color: "oklch(70.5% .213 47.604)",
    href: "https://github.com/ferriskey",
    featured: true,
  },
  {
    titleKey: "projects.rustmotion.title",
    descKey: "projects.rustmotion.description",
    title: "Rustmotion",
    logoIcon: "mdi:motion-play-outline",
    description: "A CLI tool that renders motion design videos from JSON scenarios. No browser, no Node.js — just a single Rust binary.",
    techIcons: [
      { icon: "devicon:rust", label: "Rust" },
    ],
    color: "oklch(70.5% .213 47.604)",
    href: "https://github.com/LeadcodeDev/rustmotion",
    featured: false,
  },
  {
    titleKey: "projects.seameet.title",
    descKey: "projects.seameet.description",
    title: "Seameet",
    logoIcon: "mdi:video-outline",
    description: "A Rust-powered core engine for building video communication systems like Meet or Discord.",
    techIcons: [
      { icon: "devicon:rust", label: "Rust" },
    ],
    color: "oklch(70.5% .213 47.604)",
    href: "https://github.com/LeadcodeDev",
    featured: false,
  },
  {
    titleKey: "projects.mineral.title",
    descKey: "projects.mineral.description",
    title: "Mineral",
    logoUrl: "https://mineral-dart.dev/logo.svg",
    description: "A powerful and elegant framework for building Discord bots with Dart. Modular architecture and intuitive API.",
    techIcons: [
      { icon: "devicon:dart", label: "Dart" },
    ],
    color: "oklch(62% .16 240)",
    href: "https://github.com/music-music/music",
    featured: false,
  },
];

const featured = projects[0];
const side = projects.slice(1, 3);
const bottom = projects[3];
---

<section id="projects" class="relative py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16" data-reveal="fade-up">
      <p
        class="text-sm font-semibold text-primary uppercase tracking-widest mb-3"
        data-t="projects.label"
      >
        Projects
      </p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl" data-t="projects.title">
        Featured Projects
      </h2>
      <p
        class="mt-4 text-lg text-muted-foreground max-w-2xl mx-auto text-balance"
        data-t="projects.description"
      >
        Open-source tools and applications I have built.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-6 gap-4">
      <!-- Featured: FerrisKey (4col, 2rows) -->
      <div
        class="project-card group md:col-span-4 md:row-span-2 relative overflow-hidden rounded-2xl bg-card/50 backdrop-blur-sm border border-border/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/5"
        style={`--project-color: ${featured.color};`}
        data-reveal="fade-scale"
        data-reveal-delay="100"
      >
        <a
          href={featured.href}
          target="_blank"
          rel="noopener noreferrer"
          class="relative p-8 flex flex-col justify-between gap-6 h-full"
        >
          <!-- Header -->
          <div class="flex items-start justify-between gap-4">
            <div class="flex items-center gap-3">
              <div class="project-logo flex items-center justify-center size-12 rounded-xl bg-primary/5 border border-border/30 transition-all duration-300 overflow-hidden">
                <img src={featured.logoUrl} alt={featured.title} class="size-8 object-contain" />
              </div>
              <div>
                <h3 class="project-title text-xl font-bold text-foreground transition-colors duration-300" data-t={featured.titleKey}>
                  {featured.title}
                </h3>
                <span class="text-xs text-muted-foreground font-medium uppercase tracking-wider">Featured</span>
              </div>
            </div>
            <div class="project-arrow flex items-center justify-center size-9 rounded-lg border border-border/50 bg-card/50 shrink-0 transition-all duration-300 group-hover:rotate-45">
              <Icon icon="lucide:arrow-up-right" className="size-4 text-muted-foreground transition-colors duration-300" client:load />
            </div>
          </div>

          <!-- Description -->
          <p class="text-base text-muted-foreground leading-relaxed max-w-md" data-t={featured.descKey}>
            {featured.description}
          </p>

          <!-- Highlights -->
          <div class="space-y-3">
            {featured.highlights.map((h) => (
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center size-8 rounded-lg bg-primary/5 shrink-0">
                  <Icon icon={h.icon} className="size-4 text-muted-foreground" client:load />
                </div>
                <span class="text-sm text-muted-foreground">{h.text}</span>
              </div>
            ))}
          </div>

          <!-- Tech stack with labels -->
          <div class="flex items-center gap-3 flex-wrap">
            {featured.techIcons.map((tech) => (
              <div
                class="tech-badge flex items-center gap-2 rounded-lg border border-border/30 bg-card/50 px-3 py-1.5 transition-all duration-300"
              >
                <Icon
                  icon={tech.icon}
                  className="size-5 transition-all duration-300"
                  client:load
                />
                <span class="text-xs text-muted-foreground font-medium">{tech.label}</span>
              </div>
            ))}
          </div>
        </a>
      </div>

      <!-- Side projects (2col each, stacked) -->
      {side.map((project, i) => (
        <div
          class="project-card group md:col-span-2 relative overflow-hidden rounded-2xl bg-card/50 backdrop-blur-sm border border-border/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/5"
          style={`--project-color: ${project.color};`}
          data-reveal="fade-scale"
          data-reveal-delay={String(200 + i * 100)}
        >
          <a
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
            class="relative p-6 flex flex-col gap-4 h-full"
          >
            <!-- Header -->
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <div class="project-logo flex items-center justify-center size-10 rounded-lg bg-primary/5 border border-border/30 transition-all duration-300">
                  <Icon icon={project.logoIcon} className="size-5 text-muted-foreground transition-colors duration-300" client:load />
                </div>
                <h3 class="project-title text-lg font-semibold text-foreground transition-colors duration-300" data-t={project.titleKey}>
                  {project.title}
                </h3>
              </div>
              <div class="project-arrow flex items-center justify-center size-8 rounded-lg border border-border/50 bg-card/50 shrink-0 transition-all duration-300 group-hover:rotate-45">
                <Icon icon="lucide:arrow-up-right" className="size-3.5 text-muted-foreground transition-colors duration-300" client:load />
              </div>
            </div>

            <!-- Description -->
            <p class="text-sm text-muted-foreground leading-relaxed flex-1" data-t={project.descKey}>
              {project.description}
            </p>

            <!-- Tech icons -->
            <div class="flex items-center gap-2">
              {project.techIcons.map((tech) => (
                <div
                  class="tech-badge flex items-center justify-center size-10 rounded-lg border border-border/30 bg-card/50 transition-all duration-300"
                  title={tech.label}
                >
                  <Icon
                    icon={tech.icon}
                    className="size-5 grayscale opacity-40 transition-all duration-300"
                    client:load
                  />
                </div>
              ))}
            </div>
          </a>
        </div>
      ))}

      <!-- Bottom: Mineral (full width) -->
      <div
        class="project-card group md:col-span-6 relative overflow-hidden rounded-2xl bg-card/50 backdrop-blur-sm border border-border/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/5"
        style={`--project-color: ${bottom.color};`}
        data-reveal="fade-scale"
        data-reveal-delay="400"
      >
        <a
          href={bottom.href}
          target="_blank"
          rel="noopener noreferrer"
          class="relative p-6 sm:p-8 flex flex-col sm:flex-row sm:items-center gap-6 h-full"
        >
          <!-- Left: logo + title -->
          <div class="flex items-center gap-4 shrink-0">
            <div class="project-logo flex items-center justify-center size-12 rounded-xl bg-primary/5 border border-border/30 transition-all duration-300 overflow-hidden">
              <img src={bottom.logoUrl} alt={bottom.title} class="size-8 object-contain" />
            </div>
            <div>
              <h3 class="project-title text-xl font-semibold text-foreground transition-colors duration-300" data-t={bottom.titleKey}>
                {bottom.title}
              </h3>
            </div>
          </div>

          <!-- Description -->
          <p class="text-sm text-muted-foreground leading-relaxed flex-1" data-t={bottom.descKey}>
            {bottom.description}
          </p>

          <!-- Tech + arrow -->
          <div class="flex items-center gap-3 shrink-0">
            {bottom.techIcons.map((tech) => (
              <div
                class="tech-badge flex items-center justify-center size-10 rounded-lg border border-border/30 bg-card/50 transition-all duration-300"
                title={tech.label}
              >
                <Icon
                  icon={tech.icon}
                  className="size-5 grayscale opacity-40 transition-all duration-300"
                  client:load
                />
              </div>
            ))}
            <div class="project-arrow flex items-center justify-center size-9 rounded-lg border border-border/50 bg-card/50 shrink-0 transition-all duration-300 group-hover:rotate-45 ml-2">
              <Icon icon="lucide:arrow-up-right" className="size-4 text-muted-foreground transition-colors duration-300" client:load />
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- View all link -->
    <div class="text-center mt-8" data-reveal="fade-up" data-reveal-delay="500">
      <a
        href="https://github.com/LeadcodeDev"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors"
      >
        <span data-t="projects.viewAll">View all on GitHub</span>
        <Icon icon="lucide:arrow-up-right" className="size-4" client:load />
      </a>
    </div>
  </div>
</section>

<style>
  .project-card {
    border-color: color-mix(in oklch, var(--project-color) 20%, transparent);
  }
  .project-card:hover {
    border-color: color-mix(in oklch, var(--project-color) 40%, transparent);
  }
  .project-card .project-logo {
    background: color-mix(in oklch, var(--project-color) 10%, transparent);
    border-color: color-mix(in oklch, var(--project-color) 15%, transparent);
  }
  .project-card:hover .project-logo {
    background: color-mix(in oklch, var(--project-color) 20%, transparent);
    border-color: color-mix(in oklch, var(--project-color) 25%, transparent);
  }
  .project-card .project-logo :global(svg) {
    color: var(--project-color);
  }
  .project-card .project-title {
    color: var(--project-color);
  }
  .project-card:hover .project-arrow {
    border-color: var(--project-color);
    background: color-mix(in oklch, var(--project-color) 10%, transparent);
  }
  .project-card:hover .project-arrow :global(svg) {
    color: var(--project-color);
  }
  .project-card .tech-badge :global(svg) {
    filter: grayscale(0);
    opacity: 1;
  }
</style>
