---
import { Icon } from "@iconify/react";
---

<section class="relative py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-12" data-reveal="fade-up">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">Platform</p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
        Not isolated projects.<br class="hidden sm:block" /> A coherent platform.
      </h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-2xl">
        Each product has a defined role, clear service boundaries, and a shared identity foundation.
      </p>
    </div>

    <!-- Architecture grid -->
    <div class="grid grid-cols-1 lg:grid-cols-[1.65fr_1fr] gap-4">

      <!-- FerrisKey — Foundation -->
      <a
        href="https://ferriskey.rs"
        target="_blank"
        rel="noopener noreferrer"
        class="group rounded-2xl border border-border bg-card p-8 flex flex-col gap-8 transition-all duration-200 hover:border-border/80 hover:shadow-md"
        data-reveal="fade-up"
        data-reveal-delay="100"
      >
        <!-- Logo + arrow -->
        <div class="flex items-start justify-between">
          <div class="flex items-center justify-center size-14 rounded-xl border border-border bg-white shadow-sm shrink-0">
            <img src="https://ferriskey.rs/logo.svg" alt="FerrisKey" class="size-9" />
          </div>
          <div class="flex items-center justify-center size-9 rounded-lg border border-border/60 bg-background shrink-0 transition-all duration-200 group-hover:rotate-45">
            <Icon icon="lucide:arrow-up-right" className="size-4 text-muted-foreground" client:load />
          </div>
        </div>

        <!-- Content -->
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4 flex-wrap">
            <h3 class="text-xl font-bold text-foreground">FerrisKey</h3>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full border border-orange-400/30 bg-orange-400/10 text-orange-500 dark:text-orange-400">
              Identity Foundation
            </span>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed">
            The IAM layer of the platform. Authentication, authorization, OIDC, and multi-tenant policy — every service authenticates through FerrisKey. The foundation everything else depends on.
          </p>
        </div>

        <!-- Tags -->
        <div class="flex gap-2 flex-wrap">
          {["OIDC", "Multi-tenancy", "Policy engine", "Rust", "Kubernetes"].map((tag) => (
            <span class="text-xs text-muted-foreground border border-border/60 rounded-lg px-2.5 py-1">{tag}</span>
          ))}
        </div>
      </a>

      <!-- Right column -->
      <div class="flex flex-col gap-3">

        <!-- Separator -->
        <div class="flex items-center gap-3" data-reveal="fade-up" data-reveal-delay="150">
          <div class="h-px flex-1 bg-border/30"></div>
          <span class="text-[10px] font-bold text-muted-foreground/40 uppercase tracking-[0.2em] whitespace-nowrap">Built on FerrisKey</span>
          <div class="h-px flex-1 bg-border/30"></div>
        </div>

        <!-- Ferriscord -->
        <a
          href="https://github.com/ferrislabs"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex-1 rounded-2xl border border-border bg-card p-6 flex flex-col gap-5 transition-all duration-200 hover:border-border/80 hover:shadow-md"
          data-reveal="fade-up"
          data-reveal-delay="200"
        >
          <div class="flex items-start justify-between">
            <div class="flex items-center justify-center size-10 rounded-xl border border-border bg-violet-500/10">
              <Icon icon="mdi:clipboard-check-outline" className="size-5 text-violet-500 dark:text-violet-400" client:load />
            </div>
            <div class="flex items-center justify-center size-7 rounded-lg border border-border/60 bg-background transition-all duration-200 group-hover:rotate-45">
              <Icon icon="lucide:arrow-up-right" className="size-3 text-muted-foreground" client:load />
            </div>
          </div>

          <div>
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <h3 class="text-sm font-semibold text-foreground">Ferriscord</h3>
              <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full border border-violet-500/25 bg-violet-500/10 text-violet-500 dark:text-violet-400">Realtime</span>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed">
              Event-driven realtime collaboration engine. Reliable message delivery, ScyllaDB for low-latency storage, Kafka for horizontal coordination.
            </p>
          </div>

          <div class="flex gap-1.5 flex-wrap">
            {["Rust", "Kafka", "ScyllaDB"].map((tag) => (
              <span class="text-[10px] text-muted-foreground border border-border/60 rounded-md px-2 py-0.5">{tag}</span>
            ))}
          </div>
        </a>

        <!-- Ferrisletter -->
        <a
          href="https://github.com/ferrislabs"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex-1 rounded-2xl border border-border bg-card p-6 flex flex-col gap-5 transition-all duration-200 hover:border-border/80 hover:shadow-md"
          data-reveal="fade-up"
          data-reveal-delay="250"
        >
          <div class="flex items-start justify-between">
            <div class="flex items-center justify-center size-10 rounded-xl border border-border bg-blue-500/10">
              <Icon icon="mdi:email-open-multiple-outline" className="size-5 text-blue-500 dark:text-blue-400" client:load />
            </div>
            <div class="flex items-center justify-center size-7 rounded-lg border border-border/60 bg-background transition-all duration-200 group-hover:rotate-45">
              <Icon icon="lucide:arrow-up-right" className="size-3 text-muted-foreground" client:load />
            </div>
          </div>

          <div>
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <h3 class="text-sm font-semibold text-foreground">Ferrisletter</h3>
              <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full border border-blue-500/25 bg-blue-500/10 text-blue-500 dark:text-blue-400">Messaging</span>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed">
              Newsletter and transactional messaging platform. Clean delivery guarantees, identity-aware routing from FerrisKey.
            </p>
          </div>

          <div class="flex gap-1.5 flex-wrap">
            {["Postgres", "Architecture", "Open source"].map((tag) => (
              <span class="text-[10px] text-muted-foreground border border-border/60 rounded-md px-2 py-0.5">{tag}</span>
            ))}
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
