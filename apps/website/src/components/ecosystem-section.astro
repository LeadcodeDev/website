---
import { Icon } from "@iconify/react";
---

<section class="relative py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-12" data-reveal="fade-up">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">Platform</p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
        Not isolated projects.<br class="hidden sm:block" /> A coherent platform.
      </h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-2xl">
        Each product has a defined role, clear service boundaries, and a shared identity foundation.
      </p>
    </div>

    <!-- FerrisKey — featured foundation -->
    <a
      href="https://ferriskey.rs"
      target="_blank"
      rel="noopener noreferrer"
      class="group relative flex flex-col sm:flex-row items-start gap-6 rounded-2xl border border-border bg-card p-7 sm:p-8 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:border-orange-400/40 overflow-hidden"
      data-reveal="fade-up"
      data-reveal-delay="100"
    >
      <!-- Left orange accent bar -->
      <div class="absolute left-0 top-0 bottom-0 w-1 bg-orange-400/60 rounded-l-2xl"></div>

      <!-- Logo -->
      <div class="flex items-center justify-center size-14 rounded-xl border border-border bg-white shrink-0 shadow-sm ml-2">
        <img src="https://ferriskey.rs/logo.svg" alt="FerrisKey" class="size-8" />
      </div>

      <!-- Content -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-3 flex-wrap">
          <h3 class="text-xl font-bold text-foreground">FerrisKey</h3>
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full border border-orange-400/30 bg-orange-400/10 text-orange-500 dark:text-orange-400">
            Identity Foundation
          </span>
        </div>
        <p class="text-sm text-muted-foreground leading-relaxed mb-4 max-w-2xl">
          The IAM layer of the platform. Authentication, authorization, OIDC, and multi-tenant policy — every service authenticates through FerrisKey. The foundation everything else depends on.
        </p>
        <div class="flex gap-2 flex-wrap">
          {["OIDC", "Multi-tenancy", "Policy engine", "Rust", "Kubernetes"].map((tag) => (
            <span class="text-xs text-muted-foreground border border-border/60 rounded-lg px-2.5 py-1 bg-muted/30">{tag}</span>
          ))}
        </div>
      </div>

      <!-- Arrow -->
      <div class="hidden sm:flex items-center justify-center size-9 rounded-lg border border-border/60 bg-background shrink-0 transition-all duration-300 group-hover:rotate-45 group-hover:border-orange-400/50 group-hover:bg-orange-400/5">
        <Icon icon="lucide:arrow-up-right" className="size-4 text-muted-foreground group-hover:text-orange-400 transition-colors duration-300" client:load />
      </div>
    </a>

    <!-- "Built on" divider -->
    <div class="flex items-center gap-4 my-4" data-reveal="fade-up" data-reveal-delay="200">
      <div class="h-px flex-1 bg-border/30"></div>
      <span class="text-[10px] font-bold text-muted-foreground/40 uppercase tracking-[0.2em] whitespace-nowrap">Built on FerrisKey</span>
      <div class="h-px flex-1 bg-border/30"></div>
    </div>

    <!-- Ferriscord + Ferrisletter -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" data-reveal="fade-up" data-reveal-delay="300">

      <!-- Ferriscord (violet) -->
      <a
        href="https://github.com/ferrislabs"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative rounded-2xl border border-border bg-card p-6 flex flex-col transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:border-violet-500/40 overflow-hidden"
      >
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-violet-500/50 rounded-l-2xl"></div>

        <div class="flex items-start justify-between mb-5 pl-2">
          <div class="flex items-center justify-center size-11 rounded-xl border border-violet-500/20 bg-violet-500/10">
            <Icon icon="mdi:clipboard-check-outline" className="size-5 text-violet-500 dark:text-violet-400" client:load />
          </div>
          <div class="flex items-center justify-center size-8 rounded-lg border border-border/60 bg-background transition-all duration-300 group-hover:rotate-45 group-hover:border-violet-500/40 group-hover:bg-violet-500/5">
            <Icon icon="lucide:arrow-up-right" className="size-3.5 text-muted-foreground group-hover:text-violet-500 transition-colors duration-300" client:load />
          </div>
        </div>

        <div class="flex items-center gap-2.5 mb-2 pl-2">
          <h3 class="text-base font-semibold text-foreground">Ferriscord</h3>
          <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full border border-violet-500/25 bg-violet-500/10 text-violet-500 dark:text-violet-400">Realtime Layer</span>
        </div>
        <p class="text-sm text-muted-foreground leading-relaxed flex-1 pl-2">
          Event-driven realtime collaboration engine. Protocol design for reliable message delivery, ScyllaDB for low-latency storage, and Kafka for horizontal coordination.
        </p>
        <div class="flex gap-2 mt-4 flex-wrap pl-2">
          {["Rust", "Kafka", "ScyllaDB"].map((tag) => (
            <span class="text-xs text-muted-foreground border border-border/60 rounded-lg px-2.5 py-1 bg-muted/30">{tag}</span>
          ))}
        </div>
      </a>

      <!-- Ferrisletter (blue) -->
      <a
        href="https://github.com/ferrislabs"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative rounded-2xl border border-border bg-card p-6 flex flex-col transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:border-blue-500/40 overflow-hidden"
      >
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-blue-500/50 rounded-l-2xl"></div>

        <div class="flex items-start justify-between mb-5 pl-2">
          <div class="flex items-center justify-center size-11 rounded-xl border border-blue-500/20 bg-blue-500/10">
            <Icon icon="mdi:email-open-multiple-outline" className="size-5 text-blue-500 dark:text-blue-400" client:load />
          </div>
          <div class="flex items-center justify-center size-8 rounded-lg border border-border/60 bg-background transition-all duration-300 group-hover:rotate-45 group-hover:border-blue-500/40 group-hover:bg-blue-500/5">
            <Icon icon="lucide:arrow-up-right" className="size-3.5 text-muted-foreground group-hover:text-blue-500 transition-colors duration-300" client:load />
          </div>
        </div>

        <div class="flex items-center gap-2.5 mb-2 pl-2">
          <h3 class="text-base font-semibold text-foreground">Ferrisletter</h3>
          <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full border border-blue-500/25 bg-blue-500/10 text-blue-500 dark:text-blue-400">Messaging Layer</span>
        </div>
        <p class="text-sm text-muted-foreground leading-relaxed flex-1 pl-2">
          Newsletter and transactional messaging platform. Clean delivery guarantees, platform boundary design, and identity-aware routing from FerrisKey.
        </p>
        <div class="flex gap-2 mt-4 flex-wrap pl-2">
          {["Postgres", "Architecture", "Open source"].map((tag) => (
            <span class="text-xs text-muted-foreground border border-border/60 rounded-lg px-2.5 py-1 bg-muted/30">{tag}</span>
          ))}
        </div>
      </a>
    </div>
  </div>
</section>
