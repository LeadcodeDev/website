---
import { Icon } from "@iconify/react";
import { Button } from "@explainer/ui";
---

<div id="contact" class="w-full max-w-6xl mx-auto px-5 py-16 sm:py-24 lg:py-32">
  <div
    class="relative overflow-hidden border rounded-2xl bg-primary/5 px-8 py-16 sm:px-16 sm:py-20 text-center"
  >
    <!-- Decorative circles -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div
        class="absolute -top-16 -left-16 w-56 h-56 rounded-full border-2 border-primary/10"
      >
      </div>

      <div
        class="absolute -bottom-20 -right-20 w-64 h-64 rounded-full border-2 border-primary/10"
      >
      </div>
      <div
        class="absolute -bottom-12 -right-12 w-44 h-44 rounded-full border border-primary/[0.07]"
      >
      </div>

      <div class="absolute top-8 right-1/4 size-2.5 rounded-full bg-primary/10">
      </div>
      <div
        class="absolute bottom-10 left-[30%] size-2 rounded-full bg-primary/8"
      >
      </div>
    </div>

    <h2 class="text-3xl font-semibold text-foreground sm:text-4xl" data-t="contact.title">
      Let's work together
    </h2>
    <p class="mt-4 text-lg text-muted-foreground max-w-xl mx-auto text-balance" data-t="contact.description">
      Have a project in mind or just want to chat? Feel free to reach out.
    </p>

    <div class="mt-8 flex justify-center flex-wrap gap-4">
      <Button size="lg" className="cursor-pointer" client:load>
        <a href="mailto:baptiste.parmantier.pro@gmail.com" class="flex gap-2">
          <Icon
            icon="mdi:email-outline"
            aria-hidden="true"
            className="size-5"
            client:load
          />
          <span data-t="contact.email">Send an email</span>
        </a>
      </Button>
      <Button variant="outline" size="lg" className="cursor-pointer" client:load>
        <a
          href="https://www.linkedin.com/in/baptiste-parmantier"
          target="_blank"
          rel="noopener noreferrer"
          class="flex gap-2"
        >
          <Icon
            icon="mdi:linkedin"
            aria-hidden="true"
            className="size-5"
            client:load
          />
          <span data-t="contact.linkedin">LinkedIn</span>
        </a>
      </Button>
    </div>

    <div class="mt-8 flex justify-center gap-6">
      <a
        href="https://github.com/LeadcodeDev"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center size-10 rounded-full border border-border bg-card text-muted-foreground hover:text-primary hover:border-primary/30 transition-colors cursor-pointer"
        aria-label="GitHub"
      >
        <Icon icon="mdi:github" className="size-5" client:load />
      </a>
      <a
        href="https://www.linkedin.com/in/baptiste-parmantier"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center size-10 rounded-full border border-border bg-card text-muted-foreground hover:text-primary hover:border-primary/30 transition-colors cursor-pointer"
        aria-label="LinkedIn"
      >
        <Icon icon="mdi:linkedin" className="size-5" client:load />
      </a>
      <a
        href="mailto:baptiste.parmantier.pro@gmail.com"
        class="flex items-center justify-center size-10 rounded-full border border-border bg-card text-muted-foreground hover:text-primary hover:border-primary/30 transition-colors cursor-pointer"
        aria-label="Email"
      >
        <Icon icon="mdi:email-outline" className="size-5" client:load />
      </a>
    </div>
  </div>
</div>
